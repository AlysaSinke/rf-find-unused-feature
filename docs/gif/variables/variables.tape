Output "/app/docs/gif/variables/variables.gif"

Set Shell "bash"
Set FontSize 18
Set Width 1000
Set Height 600
Set Padding 20
Set Margin 0
Set CursorBlink false

Require rf-unused-feature

Type "rf-unused-feature variables"
Sleep 200ms
Enter
Wait
Sleep 7s

Type "rf-unused-feature variables --show-count"
Sleep 1200ms
Enter
Wait
Sleep 8s
